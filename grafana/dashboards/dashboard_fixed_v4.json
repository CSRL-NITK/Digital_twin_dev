    {
      "id": 7,
      "title": "Water Quality",
      "type": "gauge",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
