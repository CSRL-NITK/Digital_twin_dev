      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "efsudp8r58f7ke"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  100 - (\n    ABS(AVG(CASE WHEN s.sensor_type = 'ph' THEN r.value END) - 7.0) * 10\n    + AVG(CASE WHEN s.sensor_type = 'tds' THEN r.value END) * 0.05\n    + ABS(AVG(CASE WHEN s.sensor_type = 'temperature' THEN r.value END) - 20.0) * 2\n  ) AS \"value\"\nFROM sensor_readings r\nJOIN sensors s ON r.sensor_id = s.id\nJOIN nodes n ON s.node_id = n.id\nWHERE n.topology_id = (SELECT id FROM topologies WHERE name = '$Topology')\n  AND $__timeFilter(r.created_at)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      },
