generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  username     String   @unique @db.VarChar(255)
  email        String?  @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.Text
  role         String   @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("users")
}

model Topology {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  
  nodes       Node[]
  edges       Edge[]

  @@map("topologies")
}

model Node {
  id         Int      @id @default(autoincrement())
  topologyId Int      @map("topology_id")
  topology   Topology @relation(fields: [topologyId], references: [id], onDelete: Cascade)
  nodeName   String   @map("node_name") @db.VarChar(100)
  nodeType   String   @map("node_type") @db.VarChar(50)
  positionX  Int      @map("position_x")
  positionY  Int      @map("position_y")
  status     String   @default("healthy") @db.VarChar(30)
  attributes Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  sourceEdges Edge[] @relation("SourceEdges")
  targetEdges Edge[] @relation("TargetEdges")

  sensors     Sensor[]
  alerts      Alert[]

  @@index([topologyId])
  @@map("nodes")
}

model Edge {
  id           Int      @id @default(autoincrement())
  topologyId   Int      @map("topology_id")
  topology     Topology @relation(fields: [topologyId], references: [id], onDelete: Cascade)
  sourceNodeId Int      @map("source_node")
  targetNodeId Int      @map("target_node")
  edgeType     String   @default("pipe") @map("edge_type") @db.VarChar(50)
  sourcePortId String?  @map("source_port") @db.VarChar(100)
  targetPortId String?  @map("target_port") @db.VarChar(100)
  status       String   @default("normal") @db.VarChar(30)
  attributes   Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  sourceNode Node @relation("SourceEdges", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode Node @relation("TargetEdges", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([topologyId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("edges")
}

model Sensor {
  id          Int      @id @default(autoincrement())
  nodeId      Int      @map("node_id")
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  sensorName  String   @map("sensor_name") @db.VarChar(100)
  sensorType  String   @map("sensor_type") @db.VarChar(50)
  status      String   @default("Online") @db.VarChar(30)
  lastSeen    DateTime @default(now()) @map("last_seen") @db.Timestamp(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  readings    SensorReading[]

  @@index([nodeId])
  @@map("sensors")
}

model SensorReading {
  id          BigInt   @id @default(autoincrement())
  sensorId    Int      @map("sensor_id")
  sensor      Sensor   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  value       Float
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([sensorId, createdAt])
  @@map("sensor_readings")
}

model Alert {
  id        Int      @id @default(autoincrement())
  nodeId    Int      @map("node_id")
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  alertType String   @map("alert_type") @db.VarChar(50)
  severity  String   @db.VarChar(20)
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([nodeId])
  @@map("alerts")
}
